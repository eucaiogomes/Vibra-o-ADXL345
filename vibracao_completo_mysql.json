    },
    {
        "id": "inject_simples",
        "type": "inject",
        "z": "tab_vibracao_001",
        "name": "Tick 0.5s",
        "props": [],
        "repeat": "0.5",
        "crontab": "",
        "once": true,
        "onceDelay": "1",
        "topic": "",
        "x": 110,
        "y": 200,
        "wires": [["function_simples"]]
    },
    {
        "id": "function_simples",
        "type": "function",
        "z": "tab_vibracao_001",
        "name": "Gera vibração + alarme",
        "func": "var LIMIAR = 400;\nvar amplitudes = [80,160,250,350,450,500];\nvar tick    = context.get('tick')    || 0;\nvar estagio = context.get('estagio') || 0;\ntick++;\nif(tick >= 20){ tick=0; estagio=Math.min(estagio+1,5); }\ncontext.set('tick',tick);\ncontext.set('estagio',estagio);\nvar amp   = amplitudes[estagio];\nvar valor = Math.round((Math.random()*2-1)*amp);\nvar nomeEstagio = 'Estágio '+(estagio+1)+' ±'+amp;\nvar em = Math.abs(valor)>=LIMIAR ? 1 : 0;\n\n// Passa dados para o próximo nó salvar no banco\nmsg.dbPayload = {\n    valor:   valor,\n    estagio: estagio+1,\n    em_alarme: em\n};\n\nreturn [\n  {topic:'Vibração', payload:valor, dbPayload: msg.dbPayload},\n  {payload: nomeEstagio},\n  em ? {payload:'⚠️ ALARME! '+valor+' (±'+LIMIAR+')', dbPayload: msg.dbPayload} : null\n];",
        "outputs": 3,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 330,
        "y": 200,
        "wires": [
            ["chart_simples", "func_monta_sql"],
            ["texto_estagio"],
            ["texto_alarme"]
        ]
    },
    {
        "id": "func_monta_sql",
        "type": "function",
        "z": "tab_vibracao_001",
        "name": "Monta INSERT",
        "func": "// Monta a query para salvar no MySQL\nmsg.topic = \"INSERT INTO vibracao (valor, estagio, em_alarme) VALUES (?, ?, ?)\";\nmsg.payload = [\n    msg.dbPayload.valor,\n    msg.dbPayload.estagio,\n    msg.dbPayload.em_alarme\n];\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 550,
        "y": 300,
        "wires": [["mysql_node"]]
    },
    {
        "id": "mysql_node",
        "type": "mysql",
